# Database — set via Vercel Environment Variables after creating Vercel Postgres
# For local dev, point to a local Postgres or the Neon connection string
DATABASE_URL=postgresql://localhost:5432/src_website

# API keys for report ingestion and admin review
# Set these as Vercel Environment Variables (Settings → Environment Variables)
INGESTION_API_KEY=src-ingest-paperclip-2026
ADMIN_API_KEY=src-admin-review-2026