generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Migrations (prisma migrate deploy / db push) run over a DIRECT (unpooled)
  // connection. Prisma's migration engine takes advisory locks that are
  // unreliable through Neon's PgBouncer pooler, so build-time `migrate deploy`
  // can hang/fail against the pooled url. Runtime queries still use the pooled
  // `url`. DIRECT_URL is set in every Vercel environment to the unpooled host.
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  image                String?
  passwordHash         String?
  trialStart           DateTime?
  trialEnd             DateTime?
  isMember             Boolean   @default(false)
  currentTierId        String?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  role                 String    @default("member")
  phone                String?
  organization         String?
  country              String?
  languagePref         String    @default("en")
  marketingConsent     Boolean   @default(false)
  briefEmailOptOut     Boolean   @default(false)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  currentTier   Tier?          @relation("UserCurrentTier", fields: [currentTierId], references: [id])
  subscriptions Subscription[]
  contentShares ContentShare[]
  savedContents SavedContent[]
  accessGrants  AccessGrant[]
  customerNotes    CustomerNote[]
  customerTags     CustomerTag[]
  passwordResetTokens PasswordResetToken[]
  contentMonitors  ContentMonitor[]
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Member {
  id         String   @id @default(cuid())
  name       String
  address    String
  email      String   @unique
  profession String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Report {
  id          String    @id @default(cuid())
  title       String
  summary     String?
  content     String?
  type        String    @default("Analysis")
  section     String
  status      String    @default("pending")
  sourceRef   String?
  language    String    @default("en")
  author      String?
  minTierId   String?
  publishedAt DateTime?
  reviewedBy  String?
  reviewedAt  DateTime?
  reviewNote        String?
  designSignedOffBy String?
  designSignedOffAt DateTime?
  code              String?
  previewToken      String?   @unique
  embedding         Unsupported("vector(1536)")?
  isFreeMonthlyPick Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  contentShares  ContentShare[]
  savedContents  SavedContent[]
  accessGrants   AccessGrant[]
  monitorMatches MonitorMatch[]
  contentScores  ContentScore[]
  editorialMeta  EditorialMeta?

  @@unique([sourceRef, language])
  @@index([section])
  @@index([status])
  @@index([publishedAt])
  @@index([language])
}

model Tier {
  id                     String   @id @default(cuid())
  slug                   String   @unique
  name                   String
  description            String?
  priceMonthlyChf        Decimal  @default(0) @db.Decimal(10, 2)
  priceAnnualChf         Decimal  @default(0) @db.Decimal(10, 2)
  maxReportsMonthly      Int?
  archiveMonths          Int      @default(0)
  hasPdfDownload         Boolean  @default(false)
  hasEarlyAccess         Boolean  @default(false)
  earlyAccessHours       Int      @default(0)
  hasLiveCalls           Boolean  @default(false)
  hasBreakingAlerts      Boolean  @default(false)
  hasBespokeResearch     Boolean  @default(false)
  bespokeRequestsPerYear Int      @default(0)
  hasDedicatedManager    Boolean  @default(false)
  sortOrder              Int      @default(0)
  isPublic               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  users         User[]         @relation("UserCurrentTier")
  subscriptions Subscription[]
  accessGrants  AccessGrant[]

  @@index([slug])
  @@index([sortOrder])
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String
  tierId               String
  stripeSubscriptionId String?  @unique
  stripePriceId        String?
  stripeStatus         String?
  billingInterval      String   @default("month")
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean  @default(false)
  amountChf            Decimal  @default(0) @db.Decimal(10, 2)
  status               String   @default("active")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier Tier @relation(fields: [tierId], references: [id])

  @@index([userId])
  @@index([tierId])
  @@index([status])
  @@index([stripeSubscriptionId])
  @@index([currentPeriodEnd])
}

model ContentShare {
  id             String   @id @default(cuid())
  userId         String
  reportId       String
  shareChannel   String
  shareUrl       String   @unique
  shareToken     String   @unique
  recipientEmail String?
  recipientCount Int      @default(1)
  clicks         Int      @default(0)
  createdAt      DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportId])
  @@index([shareToken])
  @@index([shareChannel])
  @@index([createdAt])
}

model SavedContent {
  id        String   @id @default(cuid())
  userId    String
  reportId  String
  note      String?
  folder    String   @default("default")
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([userId, reportId])
  @@index([userId])
  @@index([folder])
  @@index([createdAt])
}

model AccessGrant {
  id            String    @id @default(cuid())
  userId        String
  grantType     String
  grantedTierId String?
  startsAt      DateTime
  expiresAt     DateTime?
  isPermanent   Boolean   @default(false)
  reportId      String?
  grantedBy     String
  reason        String
  status        String    @default("active")
  reminderSentAt DateTime?
  createdAt     DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier   Tier?   @relation(fields: [grantedTierId], references: [id])
  report Report? @relation(fields: [reportId], references: [id])

  @@index([userId])
  @@index([grantType])
  @@index([status])
  @@index([expiresAt])
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  noteType  String   @default("general")
  content   String
  createdBy String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model CustomerTag {
  id      String   @id @default(cuid())
  userId  String
  tag     String
  addedBy String
  addedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@index([userId])
}

model Invitation {
  id           String    @id @default(cuid())
  email        String
  token        String    @unique
  grantType    String? // free_tier | complimentary_period | null (trial only)
  tierSlug     String?
  durationDays Int?
  reason       String?
  invitedBy    String
  status       String    @default("pending") // pending | accepted | revoked | expired
  expiresAt    DateTime
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([email])
  @@index([status])
}

model ContentMonitor {
  id        String   @id @default(cuid())
  userId    String
  name      String
  keywords  String[]
  sections  String[]
  types     String[]
  languages String[]
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  matches MonitorMatch[]

  @@index([userId])
  @@index([isActive])
}

model MonitorMatch {
  id        String   @id @default(cuid())
  monitorId String
  reportId  String
  matchedOn String[]
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  monitor ContentMonitor @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  report  Report         @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([monitorId, reportId])
  @@index([monitorId])
  @@index([reportId])
  @@index([isRead])
  @@index([createdAt])
}

// Every POST /api/reports attempt — accepted, rejected, or errored — writes
// one row here. This is the observability layer between Paperclip and the
// website: when content "disappears", this table says whether it ever arrived
// and why it was turned away. Rows are never user-facing; admin dashboard only.
model IngestionLog {
  id         String   @id @default(cuid())
  outcome    String // accepted | rejected | error | unauthorized
  reason     String? // human-readable reason (e.g. heuristic name, validation error)
  code       String? // machine code (e.g. INTERNAL_TICKET_REJECTED, VALIDATION_FAILED)
  httpStatus Int
  title      String? // title as submitted (first 300 chars)
  sourceRef  String?
  language   String?
  type       String?
  section    String?
  reportId   String? // set when accepted — the created/updated Report row
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([outcome])
  @@index([sourceRef])
}

model AdminAuditLog {
  id         String   @id @default(cuid())
  actor      String // admin email, or "admin"/"system"
  action     String // e.g. grant_created, grant_revoked, invitation_sent, tier_changed, grant_expired
  targetType String? // user | grant | invitation | report
  targetId   String?
  detail     String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([action])
}

// ── SRC-CQR: Content Classification, Qualification & Rating ──
// Framework spec: SRC_Content_Classification_Rating_Framework.docx (v1.0)
// See SRC-CQR-IMPLEMENTATION.md for architecture and the Paperclip contract.

// One editorial domain of the Worldview Matrix (CEF, GEO, DPAI, ECO, SMI).
model WorldviewDomain {
  id        String           @id @default(cuid())
  code      String           @unique // CEF | GEO | DPAI | ECO | SMI
  name      String
  sortOrder Int              @default(0)
  entries   WorldviewEntry[]
}

// One topic position in the Matrix — the authoritative editorial stance
// against which content Worldview Alignment is scored.
model WorldviewEntry {
  id         String   @id @default(cuid())
  domainId   String
  topic      String // "CO2 as primary climate driver"
  position   String // "Skeptical" | "2/10" | "Supportive" | ...
  confidence String   @default("Medium") // Absolute | High | Medium | Evolving
  rationale  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  domain WorldviewDomain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
  @@index([isActive])
}

// Versioned tuning config. The current framework = the highest `version`
// with published=true. Served to Paperclip via GET /api/framework/current.
model FrameworkConfig {
  id         String   @id @default(cuid())
  version    Int      @unique // 1, 2, 3 ...
  weights    Json // { RPT: {value,trustworthiness,sourceBias,worldviewAlignment,corruptionIndex,actionability}, STY:{...}, ... }
  thresholds Json // { publishNow, reviewPublish, conditional, referenceOnly }
  flagRules  Json // declarative flag conditions
  published  Boolean  @default(false)
  note       String?
  createdAt  DateTime @default(now())

  @@index([published])
}

// Six-dimension CQR score for one report. A report may be re-scored; keep the
// latest per (reportId, frameworkVersion). Composite is recomputed server-side.
model ContentScore {
  id                 String   @id @default(cuid())
  reportId           String
  frameworkVersion   Int
  matrixVersionLabel String? // audit: Matrix state used
  scoredBy           String   @default("in-website") // in-website | paperclip | editorial

  value              Int
  trustworthiness    Int
  sourceBias         Int
  worldviewAlignment Int
  corruptionIndex    Int
  actionability      Int
  rationale          Json // { value, trustworthiness, sourceBias, worldviewAlignment, corruptionIndex, actionability }

  composite         Float // recomputed server-side from raw dims + weights
  flags             String[] // WORLDVIEW_CLASH | CORRUPTION_ALERT | CONTRARIAN_GOLD | SOURCE_RISK | BREAKING
  recommendedTier   String? // mapped onto Free | Essential | Professional | Executive
  recommendedAction String // Publish immediately | Publish with review | Conditional publish | Reference only | Reject
  contrarianFlag    Boolean  @default(false)
  editorialOverride Json? // final scores set by an editor → calibration input

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@unique([reportId, frameworkVersion])
  @@index([reportId])
  @@index([composite])
}

// "The SRC Position" editorial payload — 1:1 with a Report. Present only for
// editorial content (type "Editorial" / legacy "Opinion"). Holds the Semaform
// structure (Facts / Analysis / Room for Disagreement / The Ask), the Editorial
// Council author card, footer metadata, and nullable video/audio slots for the
// vAvatar Daily Position and audio brief (populated in a later release).
// Paperclip's "Editor" agent authors this; SRC website is the system of record.
model EditorialMeta {
  id       String @id @default(cuid())
  reportId String @unique

  // daily-position | position-paper | guest-position | debate | investigates | one-good-question | src-reads
  subBrand String @default("position-paper")
  thesis   String? // one-sentence editorial thesis shown in the header

  // Semaform body. facts is [{ claim, source, trust }]; the rest are markdown.
  facts               Json? // [{ claim: string, source?: string, trust?: number }]
  analysis            String? // "The SRC Analysis" — the argument, grounded in the facts
  roomForDisagreement String? // mandatory in every editorial: where SRC might be wrong
  theAsk              String? // concrete recommendations for decision-makers

  // Editorial Council author card
  authorTitle    String? // e.g. "Focus Area Lead, Geopolitics"
  authorCreds    String? // credentials / institutional affiliation
  authorLinkedin String?
  authorTwitter  String?

  // Footer transparency block
  methodology  String? // how this editorial was researched
  sourcesCount Int? // number of primary sources consulted
  conflicts    String? // "None" or declared conflicts of interest

  // vAvatar Daily Position + audio brief — populated in a later phase
  videoUrl      String?
  videoDuration Int? // seconds
  audioUrl      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([subBrand])
}
